  <script>
    document.querySelectorAll('.work-row').forEach(function(row) {
      row.addEventListener('click', function() {
        var item = row.closest('.work-item');
        var panel = item.querySelector('.work-panel');
        var isOpen = row.classList.contains('open');

        document.querySelectorAll('.work-row.open').forEach(function(r) {
          r.classList.remove('open');
          r.closest('.work-item').querySelector('.work-panel').classList.remove('open');
        });

        if (!isOpen) {
          row.classList.add('open');
          panel.classList.add('open');
        }
      });
    });
  </script>

