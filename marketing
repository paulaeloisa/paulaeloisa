<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>NOMBRE — Marketing Digital</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500&family=EB+Garamond:ital,wght@0,400;1,400&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --mkt-bg: #E8441A;
      --mkt-bg-dark: #C23510;
      --mkt-panel: #F0522A;
      --mkt-rule: rgba(255,255,255,0.25);
      --mkt-muted: rgba(255,255,255,0.6);
      --mkt-ink: #fff;
      --sans: 'Inter', system-ui, sans-serif;
      --serif: 'EB Garamond', Georgia, serif;
    }

    html { font-size: 13px; scroll-behavior: smooth; }

    body {
      background: var(--mkt-bg);
      color: var(--mkt-ink);
      font-family: var(--sans);
      font-weight: 300;
      line-height: 1.55;
      min-height: 100vh;
    }

    a { color: inherit; text-decoration: none; }
    a:hover { text-decoration: underline; }

    /* ── NAV ── */
    nav {
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 2rem;
      padding: 1.1rem 1.6rem;
      border-bottom: 1px solid var(--mkt-rule);
      position: sticky; top: 0;
      background: var(--mkt-bg); z-index: 100;
      align-items: center;
    }
    .brand { font-weight: 500; font-size: 1.05rem; letter-spacing: 0.06em; text-transform: uppercase; }
    .nav-links { display: flex; gap: 2rem; }
    .nav-links a { font-size: 0.85rem; letter-spacing: 0.04em; color: var(--mkt-muted); }
    .nav-links a:hover { color: var(--mkt-ink); text-decoration: none; }
    .nav-links a.active { color: var(--mkt-ink); }

    /* ── SECTION ── */
    section { border-bottom: 1px solid var(--mkt-rule); }
    .section-label {
      display: flex; justify-content: space-between;
      padding: 0.55rem 1.6rem;
      border-bottom: 1px solid var(--mkt-rule);
      font-size: 0.8rem; color: var(--mkt-muted); letter-spacing: 0.07em;
    }

    /* MKT big header */
    .mkt-header {
      padding: 2.4rem 1.6rem 2rem;
      font-size: clamp(2.4rem, 6vw, 6rem);
      font-weight: 400; line-height: 1.06; letter-spacing: -0.025em;
      color: var(--mkt-ink);
      border-bottom: 1px solid var(--mkt-rule);
    }
    .mkt-header .serif-word { font-family: var(--serif); font-style: italic; font-size: 1.08em; }

    .mkt-intro {
      padding: 1.6rem 1.6rem 2rem;
      font-size: 1.05rem;
      max-width: 640px;
      border-bottom: 1px solid var(--mkt-rule);
    }

    /* ── WORK ROW (shared pattern) ── */
    .work-item { border-bottom: 1px solid var(--mkt-rule); }
    .work-item:last-child { border-bottom: none; }

    .work-row {
      display: grid;
      grid-template-columns: 3rem 1fr auto auto 1.4rem;
      gap: 0 1.5rem;
      padding: 0.85rem 1.6rem;
      align-items: baseline;
      cursor: pointer; user-select: none;
      transition: background 0.1s;
    }
    .work-row:hover { background: rgba(255,255,255,0.08); }
    .work-row.open { background: rgba(0,0,0,0.12); }

    .work-num { color: var(--mkt-muted); font-size: 0.72rem; letter-spacing: 0.04em; }
    .work-title { font-weight: 400; font-size: 1.05rem; color: var(--mkt-ink); }
    .work-year { color: var(--mkt-muted); font-size: 0.85rem; white-space: nowrap; }
    .work-type { color: var(--mkt-muted); font-size: 0.85rem; text-align: right; white-space: nowrap; font-style: italic; font-family: var(--serif); }
    .work-arrow { color: var(--mkt-muted); font-size: 0.75rem; transition: transform 0.25s ease; display: flex; align-items: center; justify-content: flex-end; }
    .work-row.open .work-arrow { transform: rotate(90deg); }

    /* Panel */
    .work-panel { display: none; border-top: 1px solid var(--mkt-rule); background: rgba(0,0,0,0.15); }
    .work-panel.open { display: block; }
    .panel-inner { padding: 1.4rem 1.6rem 1.6rem; }

    .stills-strip {
      display: flex; gap: 0.6rem; overflow-x: auto;
      padding-bottom: 0.6rem;
      scroll-snap-type: x mandatory; -webkit-overflow-scrolling: touch;
    }
    .stills-strip::-webkit-scrollbar { height: 2px; }
    .stills-strip::-webkit-scrollbar-track { background: var(--mkt-rule); }
    .stills-strip::-webkit-scrollbar-thumb { background: var(--mkt-muted); }

    .still-img {
      flex: 0 0 auto; height: 180px; width: auto; max-width: 320px;
      object-fit: cover; scroll-snap-align: start; display: block;
      background: rgba(255,255,255,0.15);
    }
    .still-placeholder {
      flex: 0 0 240px; height: 180px;
      background: rgba(255,255,255,0.15);
      display: flex; align-items: center; justify-content: center;
      font-size: 0.75rem; color: rgba(255,255,255,0.5); letter-spacing: 0.05em;
    }

    .panel-footer {
      display: flex; align-items: center;
      justify-content: space-between; margin-top: 1rem;
    }
    .panel-desc { font-size: 0.9rem; color: var(--mkt-muted); font-style: italic; font-family: var(--serif); }

    .action-btns { display: flex; gap: 0.5rem; }
    .action-btn {
      display: inline-flex; align-items: center; gap: 0.4rem;
      font-size: 0.82rem; letter-spacing: 0.05em;
      border: 1px solid var(--mkt-ink); padding: 0.35rem 0.8rem;
      color: var(--mkt-ink); text-decoration: none !important;
      transition: background 0.15s, color 0.15s;
    }
    .action-btn:hover { background: var(--mkt-ink); color: var(--mkt-bg); }
    .action-btn svg { width: 13px; height: 13px; fill: currentColor; }

    /* ── FOOTER ── */
    footer {
      display: flex; justify-content: space-between;
      padding: 0.8rem 1.6rem; font-size: 0.78rem;
      color: var(--mkt-muted);
    }

    /* ── RESPONSIVE ── */
    @media (max-width: 680px) {
      .work-row { grid-template-columns: 2.5rem 1fr auto 1.2rem; }
      .work-type { display: none; }
      .panel-footer { flex-direction: column; align-items: flex-start; gap: 0.8rem; }
      .action-btns { flex-wrap: wrap; }
    }
  </style>
</head>
