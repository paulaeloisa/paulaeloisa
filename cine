  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg: #F9F8F5;
      --ink: #0C0C0B;
      --muted: #999;
      --rule: #CBCAC6;
      --sans: 'Inter', system-ui, sans-serif;
      --serif: 'EB Garamond', Georgia, serif;

      /* Marketing Digital accent */
      --mkt-bg: #E8441A;
      --mkt-bg-dark: #C23510;
      --mkt-panel: #F0522A;
      --mkt-rule: rgba(255,255,255,0.25);
      --mkt-muted: rgba(255,255,255,0.6);
      --mkt-ink: #fff;
    }

    html { font-size: 13px; scroll-behavior: smooth; }
    body { background: var(--bg); color: var(--ink); font-family: var(--sans); font-weight: 300; line-height: 1.55; }
    a { color: inherit; text-decoration: none; }
    a:hover { text-decoration: underline; }

    /* ── NAV ── */
    nav {
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 2rem;
      padding: 1.1rem 1.6rem;
      border-bottom: 1px solid var(--rule);
      position: sticky; top: 0;
      background: var(--bg); z-index: 100;
      align-items: center;
    }
    .brand { font-weight: 500; font-size: 1.05rem; letter-spacing: 0.06em; text-transform: uppercase; }
    .nav-links { display: flex; gap: 2rem; }
    .nav-links a { font-size: 0.85rem; letter-spacing: 0.04em; color: var(--muted); }
    .nav-links a:hover { color: var(--ink); text-decoration: none; }

    /* ── GENERIC SECTION ── */
    section { border-bottom: 1px solid var(--rule); }
    .section-label {
      display: flex; justify-content: space-between;
      padding: 0.55rem 1.6rem;
      border-bottom: 1px solid var(--rule);
      font-size: 0.8rem; color: var(--muted); letter-spacing: 0.07em;
    }

    /* ── ABOUT ── */
    .about-grid { display: grid; grid-template-columns: 1fr 1fr; }
    .about-col { padding: 2.2rem 1.6rem; font-size: 1.08rem; line-height: 1.7; }
    .about-col:first-child { border-right: 1px solid var(--rule); }
    .about-col strong { font-weight: 500; }
    .about-col em { font-family: var(--serif); font-style: italic; font-size: 1.1em; }

    /* ── SERVICES ── */
    .services-body { padding: 2rem 1.6rem 0.5rem; }
    .services-large {
      font-family: var(--sans);
      font-size: clamp(2.4rem, 6vw, 6.5rem);
      font-weight: 400; line-height: 1.06; letter-spacing: -0.025em;
    }
    .services-large .serif-word {
      font-family: var(--serif); font-style: italic; font-size: 1.08em;
    }
    .services-sub {
      padding: 1.2rem 1.6rem 2rem;
      display: flex; gap: 0.5rem; flex-wrap: wrap;
    }
    .services-sub span {
      font-size: 0.8rem; letter-spacing: 0.05em; color: var(--muted);
      border: 1px solid var(--rule);
      padding: 0.25rem 0.65rem;
    }

    /* ── CATEGORY DIVIDER ── */
    .cat-label {
      padding: 0.9rem 1.6rem 0.4rem;
      font-size: 0.78rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--ink);
      font-weight: 500;
      border-top: 1px solid var(--rule);
    }
    #cine .cat-label:first-of-type { border-top: none; }

    /* ── SHARED WORK ROW ── */
    .work-item { border-bottom: 1px solid var(--rule); }
    .work-item:last-child { border-bottom: none; }

    .work-row {
      display: grid;
      grid-template-columns: 3rem 1fr auto auto 1.4rem;
      gap: 0 1.5rem;
      padding: 0.75rem 1.6rem;
      align-items: baseline;
      cursor: pointer; user-select: none;
      transition: background 0.1s;
    }
    .work-row:hover { background: rgba(0,0,0,0.025); }
    .work-row.open { background: rgba(0,0,0,0.03); }

    .work-num { color: var(--muted); font-size: 0.72rem; letter-spacing: 0.04em; }
    .work-title { font-weight: 400; font-size: 1rem; }
    .work-year { color: var(--muted); font-size: 0.85rem; white-space: nowrap; }
    .work-type { color: var(--muted); font-size: 0.85rem; text-align: right; white-space: nowrap; font-style: italic; font-family: var(--serif); }
    .work-arrow { color: var(--muted); font-size: 0.75rem; transition: transform 0.25s ease; display: flex; align-items: center; justify-content: flex-end; }
    .work-row.open .work-arrow { transform: rotate(90deg); }

    /* ── CINE PANEL ── */
    .work-panel { display: none; border-top: 1px solid var(--rule); background: #F4F3F0; }
    .work-panel.open { display: block; }
    .panel-inner { padding: 1.4rem 1.6rem 1.6rem; }

    .stills-strip {
      display: flex; gap: 0.6rem; overflow-x: auto;
      padding-bottom: 0.6rem;
      scroll-snap-type: x mandatory; -webkit-overflow-scrolling: touch;
    }
    .stills-strip::-webkit-scrollbar { height: 2px; }
    .stills-strip::-webkit-scrollbar-track { background: var(--rule); }
    .stills-strip::-webkit-scrollbar-thumb { background: var(--muted); }

    .still-img {
      flex: 0 0 auto; height: 180px; width: auto; max-width: 320px;
      object-fit: cover; scroll-snap-align: start; display: block; background: var(--rule);
    }
    .still-placeholder {
      flex: 0 0 240px; height: 180px; background: var(--rule);
      display: flex; align-items: center; justify-content: center;
      font-size: 0.75rem; color: var(--muted); letter-spacing: 0.05em;
    }

    .panel-footer {
      display: flex; align-items: center;
      justify-content: space-between; margin-top: 1rem;
    }
    .panel-desc { font-size: 0.9rem; color: var(--muted); font-style: italic; font-family: var(--serif); }

    .action-btn {
      display: inline-flex; align-items: center; gap: 0.4rem;
      font-size: 0.82rem; letter-spacing: 0.05em;
      border: 1px solid var(--ink); padding: 0.35rem 0.8rem;
      color: var(--ink); text-decoration: none !important;
      transition: background 0.15s, color 0.15s;
    }
    .action-btn:hover { background: var(--ink); color: var(--bg); }
    .action-btn svg { width: 13px; height: 13px; fill: currentColor; }
    .action-btns { display: flex; gap: 0.5rem; }

    /* ══════════════════════════════════════
       MARKETING DIGITAL SECTION
    ══════════════════════════════════════ */
