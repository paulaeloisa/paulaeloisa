    /* ── CONTACT ── */
    .contact-body { padding: 2rem 1.6rem 2.4rem; }
    .contact-line {
      display: flex; justify-content: space-between; align-items: baseline;
      font-size: clamp(1.6rem, 4vw, 4.2rem);
      font-weight: 400; line-height: 1.15; letter-spacing: -0.02em;
    }
    .contact-line + .contact-line { margin-top: 0.2rem; }
    .contact-handle { font-family: var(--serif); font-style: italic; font-size: 0.85em; color: var(--muted); }

    /* ── FOOTER ── */
    footer { display: flex; justify-content: space-between; padding: 0.8rem 1.6rem; font-size: 0.78rem; color: var(--muted); border-top: 1px solid var(--rule); }

    /* ── RESPONSIVE ── */
    @media (max-width: 680px) {
      .about-grid { grid-template-columns: 1fr; }
      .about-col:first-child { border-right: none; border-bottom: 1px solid var(--rule); }
      .work-row { grid-template-columns: 2.5rem 1fr auto 1.2rem; }
      .work-type { display: none; }
      .contact-line { flex-direction: column; }
      .panel-footer { flex-direction: column; align-items: flex-start; gap: 0.8rem; }
      .action-btns { flex-wrap: wrap; }
    }
  </style>
</head>
